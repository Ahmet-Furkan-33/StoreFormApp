@model ProductViewModel 
@{
    ViewData["Title"] = "Ürün Yönetimi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">Ürün Listesi</h2>
        <a href="/Home/Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> Yeni Ürün Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-5 bg-light">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label small fw-bold text-muted text-uppercase">Kategoriye Göre Filtrele</label>
                        <select name="category" class="form-select form-select-lg border-0 shadow-sm"
                                asp-items="@(new SelectList(Model.Categories,"CategoryId","Name", Model.SelectedCategory))">
                            <option value="0">Tüm Ürünler (Hepsi)</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="bi bi-filter"></i> Listeyi Güncelle
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <form asp-action="EditProducts" method="post">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
            @if (Model.Products != null)
            {
                @for (var i = 0; i < Model.Products.Count; i++)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                            <input type="hidden" asp-for="@Model.Products[i].ProductId" />
                            
                            <div class="position-relative overflow-hidden bg-white mt-3" style="height: 180px;">
                                <img src="~/img/@Model.Products[i].Image" 
                                     class="w-100 h-100" 
                                     style="object-fit: contain;" 
                                     alt="@Model.Products[i].Name">
                                <span class="position-absolute top-0 start-0 badge bg-dark m-2 opacity-75">
                                    #@Model.Products[i].ProductId
                                </span>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title fw-bold mb-1 text-truncate">@Model.Products[i].Name</h6>
                                
                                <p class="text-primary fw-bold fs-5 mb-3">
                                    @Model.Products[i].Price ₺
                                </p>

                                <div class="mt-auto pt-3 border-top">
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <label class="form-check-label small fw-bold" for="active_@i">Satışta</label>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" 
                                                   asp-for="@Model.Products[i].IsActive" id="active_@i">
                                        </div>
                                    </div>

                                    <div class="row g-2">
                                        <div class="col-8">
                                            <a href="/Home/Edit/@Model.Products[i].ProductId" class="btn btn-sm btn-outline-secondary w-100">
                                                Edit
                                            </a>
                                        </div>
                                        <div class="col-4">
                                            <a href="/Home/Delete/@Model.Products[i].ProductId" class="btn btn-sm btn-outline-danger w-100">
                                                Sil
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="fixed-bottom bg-white border-top shadow-lg py-3">
            <div class="container d-flex justify-content-end">
                <button type="submit" class="btn btn-success btn-lg px-5 shadow">
                    Değişiklikleri Kaydet
                </button>
            </div>
        </div>
    </form>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        transition: all 0.3s ease;
    }
    .transition-all { transition: all 0.3s ease; }
    body { background-color: #f8f9fa; padding-bottom: 100px; }
</style>